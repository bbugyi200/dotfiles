#!/bin/sh

expand_home() {
  case "$1" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${1#\~/}"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

bob_dir=$(expand_home "${BOB_DIR:-"$HOME/bob"}")
highlights_lib_dir=${BOB_HIGHLIGHTS_LIB_DIR:-lib}

case "$highlights_lib_dir" in
  /*)
    lib_dir=$highlights_lib_dir
    ;;
  "~" | "~/"*)
    lib_dir=$(expand_home "$highlights_lib_dir")
    ;;
  *)
    lib_dir=$bob_dir/$highlights_lib_dir
    ;;
esac

if [ ! -d "$lib_dir" ]; then
  exit 0
fi

recent_file=$(find "$lib_dir" -type f -mtime 0 -print | sed -n '1p')
if [ -z "$recent_file" ]; then
  exit 0
fi

lock_dir=${TMPDIR:-/tmp}/maybe_bob_highlights_sync.lock
if ! mkdir "$lock_dir" 2>/dev/null; then
  exit 0
fi
scan_output=
cleanup() {
  if [ -n "$scan_output" ]; then
    rm -f "$scan_output"
  fi
  rmdir "$lock_dir" 2>/dev/null || true
}
trap 'cleanup' 0
trap 'cleanup; exit 129' 1
trap 'cleanup; exit 130' 2
trap 'cleanup; exit 131' 3
trap 'cleanup; exit 143' 15

if command -v bob >/dev/null 2>&1; then
  bob_bin=$(command -v bob)
else
  bob_bin=$HOME/.cargo/bin/bob
  if [ ! -x "$bob_bin" ]; then
    printf 'maybe_bob_highlights_sync: bob command not found: %s\n' "$bob_bin" >&2
    exit 127
  fi
fi

scan_output=$(mktemp "${TMPDIR:-/tmp}/maybe_bob_highlights_sync.XXXXXX") || {
  printf 'maybe_bob_highlights_sync: failed to create temporary output file\n' >&2
  exit 1
}

"$bob_bin" highlights-ref scan >"$scan_output" 2>&1
status=$?
if [ "$status" -eq 0 ]; then
  exit 0
fi

printf 'maybe_bob_highlights_sync: bob highlights-ref scan failed with status %s\n' "$status" >&2
cat "$scan_output" >&2
exit "$status"
