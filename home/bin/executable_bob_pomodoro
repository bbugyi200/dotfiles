#!/bin/bash

# shellcheck source=/home/bryan/lib/bugyi.sh
source ~/lib/bugyi.sh

set -e

function is_date_timestamp() {
  [[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}([T\ ][0-9]{2}:[0-9]{2}(:[0-9]{2})?)?$ ]]
}

function run_date() {
  local date_command_string="${DATE:-date}"
  if is_date_timestamp "${date_command_string}"; then
    date_command_string="date"
  fi

  # Allow the existing dotfiles DATE override pattern, e.g.
  # DATE='date --utc'.
  # shellcheck disable=SC2206
  local date_command=(${date_command_string})
  "${date_command[@]}" "$@"
}

function current_date() {
  if [[ -n "${BOB_NOW:-}" ]]; then
    run_date --date="${BOB_NOW}" "$@"
    return
  fi

  if [[ -n "${DATE:-}" ]] && is_date_timestamp "${DATE}"; then
    run_date --date="${DATE}" "$@"
    return
  fi

  run_date "$@"
}

function get_day_file() {
  if [[ -n "${BOB_DAY_FILE:-}" ]]; then
    printf "%s\n" "${BOB_DAY_FILE}"
    return
  fi

  printf "%s/bob/%s_day.md\n" "${HOME}" "$(current_date +%Y/%Y%m%d)"
}

function get_day_date() {
  local day_file="$1"
  local day_file_basename
  day_file_basename="$(basename "${day_file}")"

  if [[ "${day_file_basename}" =~ ^([0-9]{4})([0-9]{2})([0-9]{2})_day\.md$ ]]; then
    printf "%s-%s-%s\n" "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}"
    return
  fi

  current_date +%F
}

function colon_time() {
  local time="$1"
  printf "%s:%s\n" "${time:0:2}" "${time:2:2}"
}

function get_latest_ledger_pomodoro() {
  local day_file="$1"

  perl -Mstrict -Mwarnings -e '
    my $time_re = qr{(?:[01]?\d|2[0-3]):?[0-5]\d};
    my $in_pomodoros = 0;
    my $last;

    sub normalize_time {
      my ($time) = @_;
      $time =~ s/://g;
      $time = "0$time" if length($time) == 3;

      return if $time !~ /^([0-2]?\d)([0-5]\d)$/;

      my ($hour, $minute) = ($1, $2);
      return if $hour > 23;

      return sprintf("%02d%02d", $hour, $minute);
    }

    while (my $line = <>) {
      if ($line =~ /^##\s+Pomodoros\s*$/) {
        $in_pomodoros = 1;
        next;
      }

      if ($in_pomodoros && $line =~ /^##\s+/) {
        $in_pomodoros = 0;
      }

      next unless $in_pomodoros;

      if ($line =~ /^\s*-\s+(?:\[[^\]]*\]\s+)?(.*?)\s*$/) {
        my $task = $1;
        next unless $task =~ /\(($time_re)-($time_re)\)/;

        my ($raw_start, $raw_end) = ($1, $2);
        my ($start, $end) = (normalize_time($raw_start), normalize_time($raw_end));
        next unless defined $start && defined $end;

        $task =~ s/\(\Q$raw_start\E-\Q$raw_end\E\)//;
        $task =~ s/\s+\[\[[A-Za-z0-9_-]+::\s*[^\]]+\]\]//g;
        $task =~ s/\s+\[[A-Za-z0-9_-]+::\s*[^\]]+\]//g;
        $task =~ s/\s+/ /g;
        $task =~ s/^\s+|\s+$//g;

        $last = join("\t", $start, $end, "$start-$end", $task);
      }
    }

    print "$last\n" if defined $last;
  ' "${day_file}"
}

function format_pomodoro() {
  local range="$1"
  local task="$2"

  if [[ -n "${task}" ]]; then
    printf "%s %s\n" "${range}" "${task}"
  else
    printf "%s\n" "${range}"
  fi
}

function run() {
  if [[ "$1" == "-d" || "$1" == "--debug" ]]; then
    shift
    PS4='$LINENO: '
    set -x
  fi
  if [[ "$1" == "-v" || "$1" == "--verbose" ]]; then
    shift
    export VERBOSE=1
  fi
  if [[ "$#" -gt 0 ]]; then
    die -x 2 "Unexpected argument: %s" "$1"
  fi

  local day_file
  day_file="$(get_day_file)"
  if ! [[ -f "${day_file}" ]]; then
    log::debug "Bob day file does not exist: %s" "${day_file}"
    return 0
  fi

  local ledger_pomodoro
  ledger_pomodoro="$(get_latest_ledger_pomodoro "${day_file}")"
  if [[ -z "${ledger_pomodoro}" ]]; then
    log::debug "No Bob ledger pomodoros found in %s" "${day_file}"
    return 0
  fi

  local start_time end_time range task
  IFS=$'\t' read -r start_time end_time range task <<<"${ledger_pomodoro}"
  log::debug "Latest Bob ledger pomodoro: %s-%s %s" "${start_time}" "${end_time}" "${task}"

  local day_date end_seconds now_seconds now_minus_end
  day_date="$(get_day_date "${day_file}")"
  end_seconds="$(run_date --date="${day_date} $(colon_time "${end_time}")" +%s)"
  now_seconds="$(current_date +%s)"
  now_minus_end=$((now_seconds - end_seconds))

  local output
  output="$(format_pomodoro "${range}" "${task}")"

  if [[ ${now_minus_end} -gt 0 ]]; then
    local overdue_minutes
    overdue_minutes=$((now_minus_end / 60))

    if [[ ${now_minus_end} -lt 600 ]]; then
      output="[OVERDUE by ${overdue_minutes}m] ${output}"
    else
      output=""
    fi
  else
    local end_minus_now minutes_until_due
    end_minus_now=$((end_seconds - now_seconds))
    minutes_until_due=$(((end_minus_now / 60) + 1))
    output="[<${minutes_until_due}m] ${output}"
  fi

  if [[ -n "${output}" ]]; then
    printf "%s\n" "${output}"
  fi
}

if [[ "${SCRIPTNAME}" == "$(basename "${BASH_SOURCE[0]}")" ]]; then
  run "$@"
fi
