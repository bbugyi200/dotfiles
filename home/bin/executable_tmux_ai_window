#!/bin/bash

source ~/lib/bugyi.sh

export USAGE_GRAMMAR=(
  "[-v] [--launch PROVIDER --dir DIR]"
  "-h"
)

read -r -d '' DOC <<EOM
$(usage)

Choose an AI agent CLI and open it in a new tmux window in the current pane's
directory.

Optional Arguments
------------------
-h | --help
    View this help message.

-v | --verbose
    Enable verbose output. This option can be specified multiple times (e.g. -v, -vv, ...).

Internal Arguments
------------------
--launch PROVIDER
    Launch PROVIDER directly. Supported values: claude, codex, agy, qwen, opencode.

--dir DIR
    Directory for the launched agent. Intended for internal tmux menu callbacks.
EOM

function run() {
  parse_cli_args "$@"

  if [[ -n "${LAUNCH_PROVIDER}" ]]; then
    launch_provider "${LAUNCH_PROVIDER}" "${LAUNCH_DIR}"
  else
    show_provider_menu
  fi
}

function show_provider_menu() {
  local pane_dir
  pane_dir="$(tmux display-message -p '#{pane_current_path}')"

  # The menu callbacks re-invoke this script via tmux run-shell, which uses
  # tmux's reduced PATH (no ~/bin). Resolve our own absolute path so those
  # callbacks do not fail with exit status 127.
  local self_path
  self_path="$(resolve_user_bin "${SCRIPTNAME}")"
  if [[ -z "${self_path}" ]]; then
    self_path="${SCRIPTNAME}"
  fi

  # Compute each provider's installed status once. provider_is_installed can now
  # source NVM on a miss, so we cache the result here instead of recomputing it
  # in the menu-building loop below.
  local -a provider_installed=()
  local default_choice=""
  local installed_count=0
  local index=0
  local provider
  for index in "${!PROVIDERS[@]}"; do
    provider="${PROVIDERS[index]}"
    if provider_is_installed "${provider}"; then
      provider_installed[index]=1
      installed_count=$((installed_count + 1))
      if [[ -z "${default_choice}" ]]; then
        default_choice="${index}"
      fi
    else
      provider_installed[index]=0
    fi
  done

  if [[ "${installed_count}" -eq 0 ]]; then
    tmux_message "No AI agent CLI found (claude/codex/agy/qwen/opencode)."
    return 0
  fi

  local -a menu_args=(
    display-menu
    -b rounded
    -S "fg=#7aa2f7,bg=#1f2335"
    -T "#[align=centre,fg=#1d202f,bg=#7aa2f7,bold] Launch AI Agent "
    -s "fg=#a9b1d6,bg=#1f2335"
    -H "fg=#1d202f,bg=#7aa2f7,bold"
    -C "${default_choice}"
    -x C
    -y C
  )

  for index in "${!PROVIDERS[@]}"; do
    provider="${PROVIDERS[index]}"
    if [[ "${provider_installed[index]}" -eq 1 ]]; then
      local label
      label="$(provider_menu_label "${provider}")"

      local dir_arg
      dir_arg="$(shell_quote "${pane_dir}")"

      local shell_command
      shell_command="$(shell_quote "${self_path}") --launch ${provider} --dir ${dir_arg}"

      menu_args+=(
        "${label}"
        "$(provider_menu_key "${provider}")"
        "run-shell $(tmux_quote "${shell_command}")"
      )
    else
      menu_args+=(
        "-$(provider_disabled_menu_label "${provider}")"
        ""
        ""
      )
    fi
  done

  tmux "${menu_args[@]}"
}

function launch_provider() {
  local provider="$1"
  local pane_dir="$2"

  if ! provider_is_known "${provider}"; then
    tmux_message "Unknown AI agent provider: ${provider}"
    exit 2
  fi

  # Resolve the provider binary to an absolute path now, while we can augment
  # PATH with the user's personal bin directories and source NVM. The new tmux
  # window runs a non-interactive shell whose PATH omits ~/bin and never sources
  # ~/.zshrc, so a bare provider name (codex/claude/qwen) would otherwise fail
  # there with exit status 127.
  local provider_bin
  provider_bin="$(resolve_user_bin "$(provider_binary "${provider}")")"
  if [[ -z "${provider_bin}" ]]; then
    tmux_message "AI agent CLI is not installed: $(provider_binary "${provider}")"
    exit 1
  fi

  local ai_cmd
  ai_cmd="$(provider_command "${provider}" "$(shell_quote "${provider_bin}")")"

  # Resolve the cleanup executables to absolute paths now, for the same reason.
  # The cleanup job runs later inside tmux's server-side shell, whose PATH omits
  # ~/bin and would otherwise make the final command fail with an opaque exit
  # status 127.
  local tmux_bin fix_layout_bin renumber_bin
  tmux_bin="$(resolve_user_bin tmux)"
  fix_layout_bin="$(resolve_user_bin tm-fix-layout)"
  renumber_bin="$(resolve_user_bin tm-renumber-ai-windows)"
  if [[ -z "${tmux_bin}" || -z "${fix_layout_bin}" || -z "${renumber_bin}" ]]; then
    tmux_message "tmux_ai_window: cannot resolve cleanup commands on PATH (tmux=${tmux_bin:-MISSING}, tm-fix-layout=${fix_layout_bin:-MISSING}, tm-renumber-ai-windows=${renumber_bin:-MISSING})."
    exit 1
  fi

  # Get all window names in the current session
  local existing_windows
  existing_windows=$(tmux list-windows -F '#W')

  # Check if any window is an ai variant (ai, ai2, ai3, etc.)
  local window_name
  if ! grep -qE "^ai[0-9]*$" <<<"${existing_windows}"; then
    # No ai windows exist, create 'ai'
    window_name="ai"
  else
    # At least one ai window exists, find next available number
    local n
    n=2
    while grep -q "^ai${n}$" <<<"${existing_windows}"; do
      ((n++))
    done
    window_name="ai${n}"
  fi

  # Create a unique channel for this window's cleanup signal
  local channel
  channel="ai-cleanup-$$"

  # Run waiter in tmux's background (-b flag)
  # This keeps the process alive as a tmux-managed job, avoiding orphaning issues.
  # Absolute paths are used so the job does not depend on tmux's reduced PATH.
  local cleanup_cmd
  cleanup_cmd="$(shell_quote "${tmux_bin}") wait-for $(shell_quote "${channel}")"
  cleanup_cmd+=" && sleep 0.1"
  cleanup_cmd+=" && $(shell_quote "${fix_layout_bin}")"
  cleanup_cmd+=" && $(shell_quote "${renumber_bin}")"
  tmux run-shell -b "${cleanup_cmd}"

  # Create window - when AI CLI exits, signal the channel before window closes
  tmux new-window -n "${window_name}" "cd $(shell_quote "${pane_dir}") && clear && ${ai_cmd}; tmux wait-for -S $(shell_quote "${channel}")"
}

function parse_cli_args() {
  log::debug "Command-Line Arguments: ($*)"

  local parsed_args
  if ! parsed_args="$(getopt -o "hv" -l "help,verbose,launch:,dir:" -- "$@")"; then
    die -x 2 "Invalid command-line arguments."
  fi
  eval set -- "${parsed_args}"

  VERBOSE=0
  LAUNCH_PROVIDER=""
  LAUNCH_DIR=""
  while [[ -n "$1" ]]; do
    case $1 in
    -h | --help)
      echo "${DOC}"
      exit 0
      ;;
    -v | --verbose)
      VERBOSE=$((VERBOSE + 1))
      ;;
    --launch)
      shift
      LAUNCH_PROVIDER="$1"
      ;;
    --dir)
      shift
      LAUNCH_DIR="$1"
      ;;
    --)
      shift
      break
      ;;
    esac
    shift
  done

  if [[ "${VERBOSE}" -gt 1 ]]; then
    PS4='$LINENO: '
    set -x
  fi

  if [[ "$#" -gt 0 ]]; then
    die -x 2 "Unexpected positional arguments: $*"
  fi

  if [[ -n "${LAUNCH_PROVIDER}" && -z "${LAUNCH_DIR}" ]]; then
    die -x 2 "--launch requires --dir."
  fi

  if [[ -z "${LAUNCH_PROVIDER}" && -n "${LAUNCH_DIR}" ]]; then
    die -x 2 "--dir requires --launch."
  fi

  if [[ -n "${LAUNCH_PROVIDER}" ]] && ! provider_is_known "${LAUNCH_PROVIDER}"; then
    die -x 2 "Unsupported provider: ${LAUNCH_PROVIDER}"
  fi

  readonly DOC
  readonly LAUNCH_DIR
  readonly LAUNCH_PROVIDER
  readonly VERBOSE
}

readonly -a PROVIDERS=(claude codex agy qwen opencode)

function provider_is_known() {
  case "$1" in
  claude | codex | agy | qwen | opencode)
    return 0
    ;;
  *)
    return 1
    ;;
  esac
}

function provider_binary() {
  case "$1" in
  claude)
    echo "claude"
    ;;
  codex)
    echo "codex"
    ;;
  agy)
    echo "agy"
    ;;
  qwen)
    echo "qwen"
    ;;
  opencode)
    echo "opencode"
    ;;
  esac
}

# Build the shell command that launches a provider. The binary is passed in as
# an already shell-quoted absolute path ("${bin}") so the launch command does not
# depend on the new window's reduced, non-interactive PATH.
function provider_command() {
  local provider="$1"
  local bin="$2"
  case "${provider}" in
  claude)
    echo "EDITOR=nvim ${bin} --effort max --dangerously-skip-permissions"
    ;;
  codex)
    echo "${bin} -c 'model_reasoning_effort=\"xhigh\"' --dangerously-bypass-approvals-and-sandbox"
    ;;
  agy)
    echo "${bin} --model 'Gemini 3.5 Flash (High)' --dangerously-skip-permissions"
    ;;
  qwen)
    echo "${bin} --model qwen3.6-plus --yolo"
    ;;
  opencode)
    echo "${bin}"
    ;;
  esac
}

function provider_menu_key() {
  case "$1" in
  claude)
    echo "c"
    ;;
  codex)
    echo "x"
    ;;
  agy)
    echo "a"
    ;;
  qwen)
    echo "q"
    ;;
  opencode)
    echo "o"
    ;;
  esac
}

function provider_display_name() {
  case "$1" in
  claude)
    echo "claude"
    ;;
  codex)
    echo "codex"
    ;;
  agy)
    echo "agy"
    ;;
  qwen)
    echo "qwen"
    ;;
  opencode)
    echo "opencode"
    ;;
  esac
}

function provider_description() {
  case "$1" in
  claude)
    echo "Anthropic"
    ;;
  codex)
    echo "OpenAI"
    ;;
  agy)
    echo "Antigravity"
    ;;
  qwen)
    echo "Alibaba"
    ;;
  opencode)
    echo "SST"
    ;;
  esac
}

function provider_accent() {
  case "$1" in
  claude)
    echo "#e0af68"
    ;;
  codex)
    echo "#9ece6a"
    ;;
  agy)
    echo "#7aa2f7"
    ;;
  qwen)
    echo "#bb9af7"
    ;;
  opencode)
    echo "#7dcfff"
    ;;
  esac
}

function provider_is_installed() {
  resolve_user_bin "$(provider_binary "$1")" >/dev/null 2>&1
}

function provider_menu_label() {
  local provider="$1"

  printf "#[fg=%s,bold]%-10s#[fg=#565f89,nobold] %s" \
    "$(provider_accent "${provider}")" \
    "$(provider_display_name "${provider}")" \
    "$(provider_description "${provider}")"
}

function provider_disabled_menu_label() {
  local provider="$1"

  printf "#[fg=#565f89]%-10s %s not installed" \
    "$(provider_display_name "${provider}")" \
    "$(provider_description "${provider}")"
}

# Resolve a command to an absolute path for use inside tmux callbacks, which run
# under tmux's reduced server-side PATH (no ~/bin) and a non-interactive shell
# that never sources ~/.zshrc.
#
# Resolution happens in two passes:
#   1. Search the inherited PATH plus the user's personal bin directories
#      (~/bin, ~/.local/bin). This covers tmux, the tm-* helpers, and any
#      provider installed there (e.g. agy in ~/.local/bin).
#   2. If still not found, source NVM in a subshell and retry. Several providers
#      (codex, claude, qwen) are NVM-managed binaries that only land on PATH once
#      NVM is sourced, which an interactive shell would normally do via ~/.zshrc.
#
# Prints the absolute path on success and nothing (with a non-zero status) when
# the command cannot be found.
function resolve_user_bin() {
  local cmd="$1"
  local resolved

  if resolved="$(PATH="${HOME}/bin:${HOME}/.local/bin:${PATH}" command -v -- "${cmd}" 2>/dev/null)"; then
    printf '%s\n' "${resolved}"
    return 0
  fi

  local nvm_script="${NVM_DIR:-${HOME}/.config/nvm}/nvm.sh"
  if [[ -s "${nvm_script}" ]]; then
    resolved="$(
      # shellcheck source=/dev/null
      . "${nvm_script}" >/dev/null 2>&1
      PATH="${HOME}/bin:${HOME}/.local/bin:${PATH}" command -v -- "${cmd}" 2>/dev/null
    )"
    if [[ -n "${resolved}" ]]; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  fi

  return 1
}

function shell_quote() {
  printf "%q" "$1"
}

function tmux_quote() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//\$/\\\$}"

  printf '"%s"' "${value}"
}

function tmux_message() {
  local message="$1"

  tmux display-message "${message}" 2>/dev/null || log::warn "%s" "${message}"
}

if [[ "${SCRIPTNAME}" == "$(basename "${BASH_SOURCE[0]}")" ]]; then
  run "$@"
fi
