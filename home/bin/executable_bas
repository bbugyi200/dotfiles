#!/bin/bash
#
# BAS = Bugyi's Auto-SSH Tool
#
# Connect to a host with autossh and run a remote command (default: `tm sase`).
#
# SSH runs remote commands non-interactively, so by default the remote shell does
# not source the user's login/interactive startup files. Under that reduced
# environment, personal bin directories (e.g. ~/bin) and the NVM-managed Node bin
# directory are missing from PATH, so `tm` -- and the AI CLIs that tmux later
# launches (claude/codex/qwen) -- fail with exit status 127.
#
# To recreate the same environment an interactive login would produce, the remote
# command runs through the remote user's interactive login shell, preferring zsh.
# Before the command runs, a best-effort prelude refreshes any already-running
# tmux server's stored PATH/NVM environment so that tmux key bindings and
# run-shell callbacks (e.g. tmux_ai_window and its cleanup helpers) resolve
# commands from that same full environment rather than tmux's stale stored PATH.

host="$1"
shift

# Single-quote a string for POSIX shells: wrap it in single quotes and escape any
# embedded single quote as '\''. This is used both to quote individual split
# arguments (so spaces and special characters survive re-parsing) and to embed the
# inner command string inside the remote shell-selection wrapper. Single quoting
# is portable across bash and zsh, which the remote shells may be either of.
single_quote() {
  local s="$1"
  local escaped=${s//\'/\'\\\'\'}
  printf "'%s'" "${escaped}"
}

# Build the target command the remote interactive shell will exec:
#
#   bas HOST              -> default: `tm sase`
#   bas HOST "tm sase"    -> one-string form: the single argument is passed through
#                            verbatim so the remote shell re-parses it (preserves
#                            the historical behavior)
#   bas HOST tm sase ...  -> split form: each argument is single-quoted and joined,
#                            so arguments with spaces or special characters survive
#                            intact instead of being mangled by a lossy "$*" join
if [[ "$#" -eq 0 ]]; then
  target_cmd="tm sase"
elif [[ "$#" -eq 1 ]]; then
  target_cmd="$1"
else
  target_cmd=""
  for arg in "$@"; do
    if [[ -n "${target_cmd}" ]]; then
      target_cmd+=" "
    fi
    target_cmd+="$(single_quote "${arg}")"
  done
fi

# Prelude that runs inside the remote interactive login shell, after startup files
# have populated PATH and the NVM variables. It is best-effort: when a tmux server
# is already running, refresh its stored global PATH and NVM environment so an
# existing server (which tmux never updates on attach) picks up the full
# interactive PATH; when no server is running yet, `tmux has-session` fails without
# starting one, so this is a no-op and `tm`/tmuxinator starts a server from this
# already-correct process environment. $PATH and $NVM_* must expand in the remote
# interactive shell, so they are kept literal here.
prelude='if command -v tmux >/dev/null 2>&1 && tmux has-session >/dev/null 2>&1; then'
prelude+=' tmux set-environment -g PATH "$PATH";'
prelude+=' [ -n "${NVM_DIR:-}" ] && tmux set-environment -g NVM_DIR "$NVM_DIR";'
prelude+=' [ -n "${NVM_BIN:-}" ] && tmux set-environment -g NVM_BIN "$NVM_BIN";'
prelude+=' [ -n "${NVM_INC:-}" ] && tmux set-environment -g NVM_INC "$NVM_INC";'
prelude+=' fi; '

# The command string the remote interactive login shell runs: refresh the tmux
# environment, then exec the requested command in place.
inner="${prelude}exec ${target_cmd}"

# Wrapper interpreted by the remote login shell that SSH uses to run the command.
# Select the remote interactive login shell:
#   1. the remote user's $SHELL, if executable;
#   2. otherwise /bin/zsh, if executable;
#   3. otherwise /bin/bash.
# zsh is invoked as an interactive login shell (-lic) so ~/.zprofile, ~/.profile,
# and ~/.zshrc all run; any other shell is invoked as a login shell (-lc). $SHELL
# and $__bas_sh must expand on the remote host, so they are kept literal here.
remote_cmd='__bas_sh="$SHELL";'
remote_cmd+=' [ -x "$__bas_sh" ] || __bas_sh=/bin/zsh;'
remote_cmd+=' [ -x "$__bas_sh" ] || __bas_sh=/bin/bash;'
remote_cmd+=' case "$__bas_sh" in *zsh) set -- -lic ;; *) set -- -lc ;; esac;'
remote_cmd+=" exec \"\$__bas_sh\" \"\$@\" $(single_quote "${inner}")"

autossh -M 0 -X -Y -t "${host}" "${remote_cmd}"
