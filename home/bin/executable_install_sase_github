#!/bin/bash

set -euo pipefail

install=false
if [[ "${1:-}" == "-i" || "${1:-}" == "--install" ]]; then
    install=true
    shift
fi

INSTALL_NAME="install_sase_github"
SASE_ORG_DIR="$HOME"/projects/github/sase-org
SASE_DIR="$SASE_ORG_DIR/sase"
SASE_CORE_DIR="$SASE_ORG_DIR/sase-core"
SASE_CORE_RS_DIR="$SASE_CORE_DIR/crates/sase_core_py"
SASE_GITHUB_DIR="$SASE_ORG_DIR/sase-github"
SASE_TELEGRAM_DIR="$SASE_ORG_DIR/sase-telegram"
AXE_STATE_DIR="$HOME/.sase/axe"
AXE_MAINTENANCE_FILE="$AXE_STATE_DIR/maintenance.json"
AXE_PID_FILE="$AXE_STATE_DIR/pid"

axe_was_running=false
maintenance_active=false
sync_warnings=()

axe_pid() {
    if [[ ! -s "$AXE_PID_FILE" ]]; then
        return 1
    fi
    local pid
    pid="$(<"$AXE_PID_FILE")"
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
        printf "%s\n" "$pid"
        return 0
    fi
    return 1
}

enter_axe_maintenance() {
    mkdir -p "$AXE_STATE_DIR"
    cat > "$AXE_MAINTENANCE_FILE" <<EOF
{
  "reason": "$INSTALL_NAME",
  "pid": $$,
  "started_at": "$(date -Iseconds)"
}
EOF
    maintenance_active=true
}

exit_axe_maintenance() {
    rm -f "$AXE_MAINTENANCE_FILE"
    maintenance_active=false
}

stop_axe_if_running() {
    if axe_pid >/dev/null; then
        axe_was_running=true
        echo ">>> Axe is running; stopping it before modifying the uv-tool venv..."
        if ! command -v sase >/dev/null 2>&1; then
            echo "ERROR: axe is running, but 'sase' is not on PATH; cannot stop axe safely." >&2
            return 1
        fi
        sase axe stop
    fi
}

record_sync_warning() {
    local repo="$1"
    local reason="$2"
    sync_warnings+=("$repo: $reason")
}

repo_is_dirty() {
    local repo="$1"
    local status_output
    if ! status_output="$(git -C "$repo" status --porcelain)"; then
        return 2
    fi
    [[ -n "$status_output" ]]
}

sync_repo_best_effort() {
    local repo="$1"
    local dirty_status

    echo ">>> Syncing $repo..."

    if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        record_sync_warning "$repo" "not a git repository or path is missing"
        return 0
    fi

    if repo_is_dirty "$repo"; then
        record_sync_warning "$repo" "dirty worktree; skipped pull"
        return 0
    else
        dirty_status=$?
        if ((dirty_status != 1)); then
            record_sync_warning "$repo" "git status failed; using local checkout"
            return 0
        fi
    fi

    if ! git -C "$repo" pull --ff-only; then
        record_sync_warning "$repo" "git pull --ff-only failed; using local checkout"
        return 0
    fi
}

print_sync_summary() {
    if ((${#sync_warnings[@]} == 0)); then
        echo ">>> Repo sync complete."
        return
    fi

    echo "WARNING: Some repos were not synced; continuing with local checkouts." >&2
    local warning
    for warning in "${sync_warnings[@]}"; do
        echo "WARNING: $warning" >&2
    done
}

probe_uv_tool_health() {
    local tool_venv
    tool_venv="$(uv tool dir)/sase"
    if [[ ! -x "$tool_venv/bin/python" ]]; then
        echo "ERROR: missing uv-tool Python at $tool_venv/bin/python" >&2
        return 1
    fi
    "$tool_venv/bin/python" -c 'import sase_core_rs; print("sase_core_rs import ok")'
    sase core health --json
}

finish() {
    local status=$?
    if [[ "$status" -ne 0 && "$maintenance_active" == true ]]; then
        echo "ERROR: $INSTALL_NAME failed; axe maintenance remains active at $AXE_MAINTENANCE_FILE." >&2
        echo "ERROR: Axe was left stopped because the uv-tool sase environment may be incomplete." >&2
    fi
    exit "$status"
}
trap finish EXIT

enter_axe_maintenance
stop_axe_if_running

for repo in "$SASE_DIR" "$SASE_CORE_DIR" "$SASE_GITHUB_DIR" "$SASE_TELEGRAM_DIR"; do
    sync_repo_best_effort "$repo"
done
print_sync_summary

if [[ ! -f "$SASE_CORE_RS_DIR/pyproject.toml" ]]; then
    echo "ERROR: Missing local sase-core-rs project: $SASE_CORE_RS_DIR/pyproject.toml" >&2
    exit 1
fi

if $install; then
    echo ">>> Installing sase via uv tool..."
    uv tool install --force --editable \
        "sase @ $SASE_DIR" \
        --with-editable "sase-core-rs @ $SASE_CORE_RS_DIR" \
        --with-editable "sase-github @ $SASE_GITHUB_DIR" \
        --with-executables-from sase-github \
        --with-editable "sase-telegram @ $SASE_TELEGRAM_DIR" \
        --with-executables-from sase-telegram
fi
echo ">>> Installing sase-core Rust backend into uv-tool venv..."
just -f "$SASE_DIR/Justfile" rust-install-uv-tool

echo ">>> Probing uv-tool sase health..."
probe_uv_tool_health

exit_axe_maintenance

if [[ "$axe_was_running" == true ]]; then
    echo ">>> Restarting axe..."
    if ! sase axe start; then
        echo "ERROR: $INSTALL_NAME succeeded, but axe restart failed." >&2
        exit 1
    fi
fi

echo ">>> $INSTALL_NAME complete."
