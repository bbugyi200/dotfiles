#!/bin/bash

set -euo pipefail

install=false
if [[ "${1:-}" == "-i" || "${1:-}" == "--install" ]]; then
    install=true
    shift
fi

INSTALL_NAME="install_sase_github"
SASE_ORG_DIR="$HOME"/projects/github/sase-org
SASE_DIR="$SASE_ORG_DIR/sase"
SASE_CORE_DIR="$SASE_ORG_DIR/sase-core"
SASE_CORE_RS_DIR="$SASE_CORE_DIR/crates/sase_core_py"
SASE_GITHUB_DIR="$SASE_ORG_DIR/sase-github"
SASE_TELEGRAM_DIR="$SASE_ORG_DIR/sase-telegram"
AXE_STATE_DIR="$HOME/.sase/axe"
AXE_MAINTENANCE_FILE="$AXE_STATE_DIR/maintenance.json"
AXE_PID_FILE="$AXE_STATE_DIR/pid"

axe_was_running=false
maintenance_active=false
sync_fail_labels=()
sync_fail_paths=()
sync_fail_reasons=()
sync_fail_commands=()
sync_fail_details=()
sync_ok_labels=()
sync_ok_files=()
sync_ok_insertions=()
sync_ok_deletions=()

axe_pid() {
    if [[ ! -s "$AXE_PID_FILE" ]]; then
        return 1
    fi
    local pid
    pid="$(<"$AXE_PID_FILE")"
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
        printf "%s\n" "$pid"
        return 0
    fi
    return 1
}

enter_axe_maintenance() {
    mkdir -p "$AXE_STATE_DIR"
    cat > "$AXE_MAINTENANCE_FILE" <<EOF
{
  "reason": "$INSTALL_NAME",
  "pid": $$,
  "started_at": "$(date -Iseconds)"
}
EOF
    maintenance_active=true
}

exit_axe_maintenance() {
    rm -f "$AXE_MAINTENANCE_FILE"
    maintenance_active=false
}

stop_axe_if_running() {
    if axe_pid >/dev/null; then
        axe_was_running=true
        echo ">>> Axe is running; stopping it before modifying the uv-tool venv..."
        if ! command -v sase >/dev/null 2>&1; then
            echo "ERROR: axe is running, but 'sase' is not on PATH; cannot stop axe safely." >&2
            return 1
        fi
        sase axe stop
    fi
}

record_sync_failure() {
    local label="$1"
    local path="$2"
    local reason="$3"
    local command="$4"
    local details="${5:-}"
    sync_fail_labels+=("$label")
    sync_fail_paths+=("$path")
    sync_fail_reasons+=("$reason")
    sync_fail_commands+=("$command")
    sync_fail_details+=("$details")
}

record_sync_success() {
    local label="$1"
    local files="$2"
    local insertions="$3"
    local deletions="$4"
    sync_ok_labels+=("$label")
    sync_ok_files+=("$files")
    sync_ok_insertions+=("$insertions")
    sync_ok_deletions+=("$deletions")
}

sync_change_counts() {
    local repo="$1"
    local before="$2"
    local after="$3"
    local numstat

    if [[ -z "$before" || -z "$after" || "$before" == "$after" ]]; then
        printf '0 0 0\n'
        return 0
    fi

    if ! numstat="$(git -C "$repo" diff --numstat "$before" "$after" 2>/dev/null)"; then
        printf '0 0 0\n'
        return 0
    fi

    if ! awk '
        NF {
            files++
            if ($1 != "-") {
                insertions += $1
            }
            if ($2 != "-") {
                deletions += $2
            }
        }
        END {
            printf "%d %d %d\n", files + 0, insertions + 0, deletions + 0
        }
    ' <<<"$numstat"; then
        printf '0 0 0\n'
    fi
}

# Sync a single required repo. Any problem (missing/non-git path, dirty
# worktree, failed status, or non-fast-forward pull) is recorded as a fatal
# sync failure instead of a tolerated warning. Returns non-zero on failure so
# the caller can keep checking the remaining repos.
sync_repo_or_record_failure() {
    local repo="$1"
    local label status_output pull_output before after counts files insertions deletions
    label="$(basename "$repo")"

    echo ">>> Syncing $label at $repo..."

    if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        record_sync_failure "$label" "$repo" "missing or not a git repository" \
            "git -C $repo rev-parse --is-inside-work-tree" ""
        return 1
    fi

    if status_output="$(git -C "$repo" status --porcelain 2>&1)"; then
        if [[ -n "$status_output" ]]; then
            record_sync_failure "$label" "$repo" "dirty worktree" \
                "git -C $repo status --porcelain" "$status_output"
            return 1
        fi
    else
        record_sync_failure "$label" "$repo" "git status failed" \
            "git -C $repo status --porcelain" "$status_output"
        return 1
    fi

    before="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"

    if ! pull_output="$(git -C "$repo" pull --ff-only 2>&1)"; then
        record_sync_failure "$label" "$repo" "git pull --ff-only failed" \
            "git -C $repo pull --ff-only" "$pull_output"
        return 1
    fi

    after="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"
    counts="$(sync_change_counts "$repo" "$before" "$after")"
    read -r files insertions deletions <<<"$counts"
    record_sync_success "$label" "${files:-0}" "${insertions:-0}" "${deletions:-0}"

    return 0
}

print_sync_summary() {
    local green="" dim="" reset=""
    if [[ -t 1 ]] && command -v tput >/dev/null 2>&1 && tput colors >/dev/null 2>&1; then
        green="$(tput setaf 2 2>/dev/null || true)"
        dim="$(tput dim 2>/dev/null || true)"
        reset="$(tput sgr0 2>/dev/null || true)"
    fi

    local label_width=0
    local label
    for label in "${sync_ok_labels[@]}"; do
        if ((${#label} > label_width)); then
            label_width="${#label}"
        fi
    done

    local i files insertions deletions file_word summary delta
    for i in "${!sync_ok_labels[@]}"; do
        files="${sync_ok_files[$i]}"
        insertions="${sync_ok_insertions[$i]}"
        deletions="${sync_ok_deletions[$i]}"

        if ((files == 0)); then
            printf '    %-*s   %sup to date%s\n' "$label_width" "${sync_ok_labels[$i]}" "$dim" "$reset"
        else
            file_word="files"
            if ((files == 1)); then
                file_word="file"
            fi
            summary="$files $file_word changed"
            delta="(+$insertions / -$deletions)"
            printf '    %-*s   %s%-17s%s %s%s%s\n' \
                "$label_width" "${sync_ok_labels[$i]}" "$green" "$summary" "$reset" "$dim" "$delta" "$reset"
        fi
    done
}

# Render a polished, dependency-free fatal error block to stderr describing
# every repo that failed to sync. Uses TTY color when available and falls back
# to plain ASCII otherwise.
print_sync_failure_error() {
    local bold="" red="" reset=""
    if [[ -t 2 ]] && command -v tput >/dev/null 2>&1 && tput colors >/dev/null 2>&1; then
        bold="$(tput bold 2>/dev/null || true)"
        red="$(tput setaf 1 2>/dev/null || true)"
        reset="$(tput sgr0 2>/dev/null || true)"
    fi

    local width=78
    local title="$INSTALL_NAME could not sync required repositories"
    local dashes border
    dashes="$(printf '%*s' "$((width + 2))" '' | tr ' ' '-')"
    border="+${dashes}+"

    {
        printf '%s%s%s\n' "$red$bold" "$border" "$reset"
        printf '%s|%s %-*s %s|%s\n' "$red$bold" "$reset" "$width" "$title" "$red$bold" "$reset"
        printf '%s%s%s\n' "$red$bold" "$border" "$reset"
        printf '\n'
        printf 'The install stopped before touching the uv-tool sase environment.\n'
        printf '\n'
        printf 'Failed repos:\n'
        local i
        for i in "${!sync_fail_labels[@]}"; do
            printf '  - %s%s%s\n' "$bold" "${sync_fail_labels[$i]}" "$reset"
            printf '    path:    %s\n' "${sync_fail_paths[$i]}"
            printf '    reason:  %s\n' "${sync_fail_reasons[$i]}"
            printf '    command: %s\n' "${sync_fail_commands[$i]}"
            if [[ -n "${sync_fail_details[$i]}" ]]; then
                printf '    details:\n'
                printf '%s\n' "${sync_fail_details[$i]}" | awk 'NR<=10{print "      " $0}'
            fi
        done
        printf '\n'
        printf 'Next steps:\n'
        printf '  1. cd into each repo above and inspect `git status`.\n'
        printf '  2. Resolve local changes, branch divergence, or remote/auth problems.\n'
        printf '  3. Re-run `%s`.\n' "$INSTALL_NAME"
    } >&2
}

validate_sase_core_rs_version() {
    if [[ ! -f "$SASE_CORE_RS_DIR/pyproject.toml" ]]; then
        echo "ERROR: Missing local sase-core-rs project: $SASE_CORE_RS_DIR/pyproject.toml" >&2
        return 1
    fi
    if ! command -v python3 >/dev/null 2>&1; then
        echo "ERROR: python3 not on PATH; cannot validate sase-core-rs version." >&2
        return 1
    fi
    python3 "$SASE_DIR/tools/validate_sase_core_rs_version" \
        --sase-core-dir "$SASE_CORE_DIR" \
        --pyproject "$SASE_DIR/pyproject.toml"
}

probe_uv_tool_health() {
    local tool_venv
    tool_venv="$(uv tool dir)/sase"
    if [[ ! -x "$tool_venv/bin/python" ]]; then
        echo "ERROR: missing uv-tool Python at $tool_venv/bin/python" >&2
        return 1
    fi
    "$tool_venv/bin/python" -c 'import sase_core_rs; print("sase_core_rs import ok")'
    sase core health --json
    sase lsp --version
    command -v sase-xprompt-lsp
}

install_xprompt_lsp() {
    if ! command -v cargo >/dev/null 2>&1; then
        echo "ERROR: cargo not on PATH; cannot install sase-xprompt-lsp." >&2
        return 1
    fi
    echo ">>> Installing sase-xprompt-lsp into cargo bin..."
    cargo install --path "$SASE_CORE_DIR/crates/sase_xprompt_lsp" --bin sase-xprompt-lsp --locked --force
}

finish() {
    local status=$?
    if [[ "$status" -ne 0 && "$maintenance_active" == true ]]; then
        echo "ERROR: $INSTALL_NAME failed; axe maintenance remains active at $AXE_MAINTENANCE_FILE." >&2
        echo "ERROR: Axe was left stopped because the uv-tool sase environment may be incomplete." >&2
    fi
    exit "$status"
}
trap finish EXIT

# Fatal sync gate: verify every required repo is clean and up to date BEFORE
# entering axe maintenance or stopping axe. If any repo fails to sync we abort
# here, while axe is still in its original state and the uv-tool environment is
# untouched. All repos are checked so the error block can list every problem.
for repo in "$SASE_DIR" "$SASE_CORE_DIR" "$SASE_GITHUB_DIR" "$SASE_TELEGRAM_DIR"; do
    sync_repo_or_record_failure "$repo" || true
done
if ((${#sync_fail_labels[@]} > 0)); then
    print_sync_failure_error
    exit 1
fi
echo ">>> Repo sync complete."
print_sync_summary

validate_sase_core_rs_version

enter_axe_maintenance
stop_axe_if_running

if ! $install; then
    tool_venv_python="$(uv tool dir)/sase/bin/python"
    if [[ ! -x "$tool_venv_python" ]]; then
        echo ">>> No uv-tool venv for sase at $(uv tool dir)/sase; promoting to full install."
        install=true
    fi
fi

if $install; then
    echo ">>> Installing sase via uv tool..."
    uv tool install --force --editable \
        --reinstall-package sase \
        --reinstall-package sase-core-rs \
        --reinstall-package sase-github \
        --reinstall-package sase-telegram \
        "sase @ $SASE_DIR" \
        --with-editable "sase-core-rs @ $SASE_CORE_RS_DIR" \
        --with-editable "sase-github @ $SASE_GITHUB_DIR" \
        --with-executables-from sase-github \
        --with-editable "sase-telegram @ $SASE_TELEGRAM_DIR" \
        --with-executables-from sase-telegram
fi
echo ">>> Installing sase-core Rust backend into uv-tool venv..."
just -f "$SASE_DIR/Justfile" rust-install-uv-tool

install_xprompt_lsp

echo ">>> Probing uv-tool sase health..."
probe_uv_tool_health

exit_axe_maintenance

if [[ "$axe_was_running" == true ]]; then
    echo ">>> Restarting axe..."
    if ! sase axe start; then
        echo "ERROR: $INSTALL_NAME succeeded, but axe restart failed." >&2
        exit 1
    fi
fi

echo ">>> $INSTALL_NAME complete."
