{
  "extensions": {
    "workspacesWithMigrationNudge": [
      "/usr/local/google/home/bbugyi"
    ]
  },
  "context": {
    "fileFiltering": {
      "enableRecursiveFileSearch": false
    }
  },
  "security": {
    "auth": {
      "selectedType": "{{ if eq .chezmoi.hostname "athena" }}oauth-personal{{ else }}gemini-api-key{{ end }}"
    }
  },
  "ui": {
    "theme": "Dracula"
  },
  "general": {
    "vimMode": true
  },
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sase_commit_stop_hook",
            "timeout": 300000
          }
        ]
      }
    ]
  },
  "policyPaths": [
    "/usr/local/google/home/bbugyi/.gemini/policies"
  ]
}
