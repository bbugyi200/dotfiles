{
  "extensions": {
    "workspacesWithMigrationNudge": [
      "/usr/local/google/home/bbugyi"
    ]
  },
  "context": {
    "fileFiltering": {
      "enableRecursiveFileSearch": false
    }
  },
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    }
  },
  "ui": {
    "theme": "Dracula"
  },
  "general": {
    "vimMode": true
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -x \"$GEMINI_PROJECT_DIR/tools/sase_stop_hook\" && \"$GEMINI_PROJECT_DIR/tools/sase_stop_hook\"",
            "timeout": 300000
          }
        ]
      }
    ]
  },
  "policyPaths": [
    "/usr/local/google/home/bbugyi/.gemini/policies"
  ]
}
