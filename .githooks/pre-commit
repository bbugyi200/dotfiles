#!/bin/sh
#
# sbd (sase-beads) pre-commit hook
#
# This hook ensures that any pending sbd issue changes are flushed to
# .sbd/issues.jsonl before the commit is created, preventing the
# race condition where daemon auto-flush fires after the commit.

# Check if sbd is available
if ! command -v sbd >/dev/null 2>&1; then
    echo "Warning: sbd command not found, skipping pre-commit flush" >&2
    exit 0
fi

# Check if we're in an sbd workspace
# For worktrees, .sbd is in the main repository root, not the worktree
SBD_DIR=""
if git rev-parse --git-dir >/dev/null 2>&1; then
    # Check if we're in a worktree
    if [ "$(git rev-parse --git-dir)" != "$(git rev-parse --git-common-dir)" ]; then
        # Worktree: .sbd is in main repo root
        MAIN_REPO_ROOT="$(git rev-parse --git-common-dir)"
        MAIN_REPO_ROOT="$(dirname "$MAIN_REPO_ROOT")"
        if [ -d "$MAIN_REPO_ROOT/.sbd" ]; then
            SBD_DIR="$MAIN_REPO_ROOT/.sbd"
        fi
    else
        # Regular repo: check current directory
        if [ -d .sbd ]; then
            SBD_DIR=".sbd"
        fi
    fi
fi

if [ -z "$SBD_DIR" ]; then
    exit 0
fi

# Skip for Dolt backend (uses its own sync mechanism, not JSONL)
if [ -f "$SBD_DIR/metadata.json" ]; then
    if grep -q '"backend"[[:space:]]*:[[:space:]]*"dolt"' "$SBD_DIR/metadata.json" 2>/dev/null; then
        exit 0
    fi
fi

# Flush pending changes to JSONL
if ! sbd sync --flush-only >/dev/null 2>&1; then
    echo "Error: Failed to flush sbd changes to storage" >&2
    echo "Run 'sbd sync --flush-only' manually to diagnose" >&2
    exit 1
fi

# If the JSONL file was modified, stage it
# For worktrees, the JSONL is in the main repo's working tree, not the worktree,
# so we can't use git add. Skip this step for worktrees.
if [ -f "$SBD_DIR/issues.jsonl" ]; then
    if [ "$(git rev-parse --git-dir)" = "$(git rev-parse --git-common-dir)" ]; then
        # Regular repo: file is in the working tree, safe to add
        git add "$SBD_DIR/issues.jsonl" 2>/dev/null || true
    fi
    # For worktrees: .sbd is in the main repo's working tree, not this worktree
    # Git rejects adding files outside the worktree, so we skip it.
    # The main repo will see the changes on the next pull/sync.
fi

exit 0
